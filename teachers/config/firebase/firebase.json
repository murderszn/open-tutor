{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "teachers/config/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }
        ]
      }
    ],
    "redirects": [
      { "source": "/", "destination": "/teachers/sites/index.html", "type": 302 },
      { "source": "/sprint", "destination": "/students/sprint.html", "type": 302 }
    ]
  }
}
